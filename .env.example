# ---------------------------------------------------------------------------
# Client (Vite — exposed to the browser, safe)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ---------------------------------------------------------------------------
# Server (Cloudflare Pages Functions — set in Pages → Settings → Environment
# variables. NEVER commit these, NEVER prefix with VITE_.)
# ---------------------------------------------------------------------------
# Same Supabase URL as above — functions need it for REST/Auth calls.
SUPABASE_URL=https://your-project.supabase.co

# Service role JWT (Supabase → Project Settings → API → service_role).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Resend API key (https://resend.com/api-keys). Starts with re_.
RESEND_API_KEY=re_...

# Public origin for portal links in emails. Use your custom domain or
# pages.dev URL. No trailing slash.
PUBLIC_APP_URL=https://prolinechch.co.nz

# Envelope From — must be on a verified domain in Resend.
# Verify prolinechch.co.nz in Resend (DKIM + SPF DNS records). Replies
# come back to whatever business.email is set to in the Settings page
# (used as the Reply-To header by the email Pages Functions).
BUSINESS_EMAIL_FROM=ProLine Aluminium <michael@prolinechch.co.nz>
